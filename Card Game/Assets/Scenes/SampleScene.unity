MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1940537496}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 818e90ceaf397064798a00a38377f0bb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panel: {fileID: 1940537496}
  tutorialText: {fileID: 1579837494}
  arrow: {fileID: 2018789863}
  steps:
  - text: This is your boss. Their reactions show how the conversation is going.
    target: {fileID: 1898693178}
    arrowOffset: {x: 0, y: 0}
    showArrow: 0
    arrowRotation: 0
  - text: This is the interaction meter. Move it to the right to win the interaction.
    target: {fileID: 913646531}
    arrowOffset: {x: 0, y: -1}
    showArrow: 1
    arrowRotation: -180
  - text: These are your cards. Each card is a different communication style. Left
      click and drag up to play a card.
    target: {fileID: 1088281624}
    arrowOffset: {x: 0, y: 2.5}
    showArrow: 1
    arrowRotation: 0
  - text: These are your available communication attempts. It corresponds with the
      communication cost on the top left of the cards.
    target: {fileID: 1267290135}
    arrowOffset: {x: 0, y: 1}
    showArrow: 1
    arrowRotation: 0
  - text: Click End Turn when you are done playing cards. Then your boss will respond.
    target: {fileID: 1530621360}
    arrowOffset: {x: 0, y: -1.5}
    showArrow: 1
    arrowRotation: -180
  - text: Good luck. Choose your responses carefully.
    target: {fileID: 1530621360}
    arrowOffset: {x: 0, y: 0}
    showArrow: 0
    arrowRotation: 0
